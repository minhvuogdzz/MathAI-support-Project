# ============================================
# CAVAT Project - Git Ignore Rules
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual Environments
.venv/
venv/
ENV/

# Jupyter Notebooks
.ipynb_checkpoints/

# Model weights (too large for Git)
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.gguf
models/weights/

# Data files (large)
*.csv
*.parquet
*.h5
*.hdf5
!data/samples/*.csv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.tmp

# Ngrok
ngrok
ngrok-v3-stable-linux-amd64.tgz

# Logs
*.log
logs/

# Environment variables (secrets)
.env
.env.local

# Node modules (Frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml

# Training outputs
wandb/
runs/
checkpoints/
*.ckpt

# Backend
backend/venv/
backend/__pycache__/
backend/.pytest_cache/
*.pyc

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
